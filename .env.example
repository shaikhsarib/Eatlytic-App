# ═══════════════════════════════════════════════════════════
# Eatlytic Environment Variables
# Copy this file to .env and fill in your actual keys
# NEVER commit .env to git!
# ═══════════════════════════════════════════════════════════

# ── LOCAL AI (Recommended: Free & Private) ──
# Run `ollama run gemma4` then set these:
LOCAL_LLM_URL=http://localhost:11434/api/chat
LOCAL_LLM_MODEL=gemma4
LOCAL_LLM_TIMEOUT=120

# ── Cloud AI (Fallbacks) ──
# Groq (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Google AI Studio (https://aistudio.google.com)
# GEMINI_API_KEY=your_google_api_key_here

# Together AI — Vision Fallback (https://api.together.xyz)
TOGETHER_API_KEY=your_together_api_key_here

# ── App Config ──
FREE_SCAN_LIMIT=10

# Security: Signed cookie secret (auto-generated if missing)
COOKIE_SECRET=your_secure_random_secret_here

# Admin endpoints (64+ chars recommended)
ADMIN_TOKEN=your_secure_random_token_here

# ── Optional Services ──
# CORS_WHITELIST=https://eatlytic.com,https://www.eatlytic.com
# RAZORPAY_KEY_ID=your_razorpay_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
