# ═══════════════════════════════════════════════════════════
# Eatlytic Environment Variables
# Copy this file to .env and fill in your actual keys
# NEVER commit .env to git!
# ═══════════════════════════════════════════════════════════

# Required: Groq API Key (get yours at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Required: Together AI Key for Vision Fallback (https://api.together.xyz)
TOGETHER_API_KEY=your_together_api_key_here

# Optional: Free scan limit per device per month
FREE_SCAN_LIMIT=10

# Required for admin endpoints (generate a strong random token)
ADMIN_TOKEN=your_secure_random_token_here

# Optional: Razorpay (required for Pro payments)
# RAZORPAY_KEY_ID=your_razorpay_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Optional: Twilio WhatsApp (required for WhatsApp channel)
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
